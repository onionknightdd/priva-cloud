# ---- macOS ----
.DS_Store

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Virtual environments
venv/
.venv/
env/
ENV/

# uv lock — the dev venv uses requirements.txt + editable installs, not uv sync
# (uv sync prunes the monolith deps); uv.lock is not the source of truth here.
uv.lock

# ---- Node / Web (priva/web + split web/{user,admin,shared}) ----
node_modules/
priva/web/dist/
priva/web/dist-admin/
priva/web/nohup.out
web/user/dist/
web/admin/dist/
npm-debug.log*
yarn-error.log*

# ---- Build artifacts / packaged releases ----
dist/*.tar.gz
dist/*.whl
# SPA assets staged into the control-panel package for the wheel build
services/control-panel/src/priva_control_panel/_web/

# ---- Runtime data ----
# Agent gateway runtime queues, locks and auth token (machine-local, may hold secrets)
.priva-agent-gateway/

# Application logs
priva/logs/
# root-level logs dir (PRIVA_LOG_DIR default when running services from the repo root)
/logs/

# Process id files
*.pid
priva/bin/*.pid

# Generic log / temp output
*.log
nohup.out

# ---- Editor / local ----
.idea/
*.swp

# ---- Claude Code local settings ----
.claude/settings.local.json

# ---- Local runtime config (ship config.example.yaml instead) ----
priva/api/config.yaml
.prod-agent-gateway/

# ---- Internal docs — not for public release ----
docs/project-analysis-report.md
docs/project-analysis-report-zh.md

# ---- Stray legacy paths a still-running server may recreate ----
/vivian/
.ds-sync/
ds-bundle/
.design-sync/
web/.ds-*
